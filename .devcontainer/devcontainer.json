{
  "name": "ROS2 Jazzy Dev Container",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "workspaceFolder": "/workspaces/ros2_ws",

  "runArgs": [
    "--network=host",
    "--ipc=host"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-iot.vscode-ros"
      ]
    }
  },

  "postCreateCommand": "rosdep update || true"
}